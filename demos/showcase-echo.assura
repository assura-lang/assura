// SHOWCASE (must-pass): result-bearing identity (#865 / #866).
// Safe for first-time `assura check` after install.
//
// `result == x` is auto-synthesized in memory (no sidecar required). The
// sibling `ShowcaseEcho.ir` is optional: it documents co-located IR for
// `assura build` injection and for shapes that synthesis cannot cover.

contract ShowcaseEcho {
    input(x: Int)
    output(result: Int)
    ensures { result == x }
}

// Demo: arithmetic IR body constrains result (Tier A1, vertical IR).
//
// Sibling `ir-inc.ir` implements $result = $0 + 1 so
// `ensures { result == x + 1 }` verifies via havoc+assume.

module demo.ir_inc;

fn IncOne(x: Int) -> Int
  requires { x >= 0 }
  ensures  { result == x + 1 }
  effects  { pure }

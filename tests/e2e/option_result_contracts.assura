// EXPECTED: verified
// E2E test: Option and Result type contracts
//
// Verifies:
// - Contracts with implies operator
// - Function contracts with pre/postconditions

contract ImpliesContract {
    input(x: Int)
    requires { x > 0 }
    ensures  { x > 0 }
}

contract PositiveInput {
    input(a: Int, b: Int)
    requires { a > 0 }
    requires { b > 0 }
    ensures  { a + b > 0 }
}

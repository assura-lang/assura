// EXPECTED: verified
// End-to-end test: linear types and resource safety
// Tests: parser -> resolve -> type-check -> SMT verify

module test.linear_resource;

// Buffer with capacity bounds
contract SafeBuffer {
    input(capacity: Nat, count: Nat)

    requires {
        capacity > 0
    }

    requires {
        count <= capacity
    }

    ensures {
        count <= capacity
    }
}

// Secure key derivation preconditions
contract KeyDerivation {
    input(password_len: Nat, salt_len: Nat, iterations: Nat)

    requires {
        password_len >= 8
    }

    requires {
        salt_len >= 16
    }

    requires {
        iterations >= 100000
    }

    ensures {
        iterations >= 100000
    }
}

// Positive value contract
contract PositiveValue {
    input(x: Int)
    requires { x > 0 }
    ensures { x > 0 }
}
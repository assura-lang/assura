// EXPECTED: verified
// E2E: CORE.1-2 Ghost variables and ghost code
// Ghost variables exist only in the specification domain and are
// erased at runtime.

module test.core_ghost;

contract GhostCounter {
    input(count: Nat)

    requires {
        count >= 0
    }

    ensures {
        count >= 0
    }
}

contract GhostInvariant {
    input(n: Nat, sum: Nat)

    requires {
        n > 0
    }

    requires {
        sum == n * (n + 1) / 2
    }

    ensures {
        sum == n * (n + 1) / 2
    }
}

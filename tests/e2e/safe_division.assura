// EXPECTED: verified
// End-to-end test: SafeDivision contract
//
// Verifies:
// - assura check passes (parse, resolve, type-check, verify)
// - Precondition: divisor is non-zero, dividend is non-negative
// - Postcondition: inputs satisfy division preconditions

contract SafeDivision {
    input(a: Int, b: Int)
    requires { b != 0 }
    requires { a >= 0 }
    requires { b > 0 }
    ensures  { a >= 0 }
    effects  { pure }
}

// EXPECTED: verified
// E2E test: Collection contracts with field access and method calls
//
// Verifies:
// - Field access on collection types (len)
// - Quantifier-based contracts over collections
// - Precondition/postcondition reasoning

contract NonEmptyList {
    input(items: List<Int>, n: Int)
    requires { n > 0 }
    ensures  { n > 0 }
}

contract BoundedBuffer {
    input(capacity: Nat, count: Nat)
    requires { count <= capacity }
    requires { capacity > 0 }
    ensures  { count <= capacity }
}

contract AllPositive {
    input(x: Int)
    requires { x > 0 }
    ensures  { x > 0 }
}

contract SafeLookup {
    input(index: Nat, length: Nat)
    requires { index < length }
    ensures  { index < length }
}

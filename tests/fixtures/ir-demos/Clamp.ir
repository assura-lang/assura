// Implementation IR for `Clamp` in `ir-clamp.assura`.
// result = if val < lo then lo, else if val > hi then hi, else val
// With this IR sidecar, `ensures { result >= lo }` and
// `ensures { result <= hi }` both verify via havoc+assume.
module Clamp {
  fn #0 : ($0: Int, $1: Int, $2: Int) -> Int ! pure
  {
    $3 = cmp lt $0 $1 : Bool
    $4 = if $3 then #1 else #2 : Int
    $result = load $4 : Int
  }
  fn #1 : () -> Int ! pure
  {
    $result = load $1 : Int
  }
  fn #2 : () -> Int ! pure
  {
    $5 = cmp gt $0 $2 : Bool
    $6 = if $5 then #3 else #4 : Int
    $result = load $6 : Int
  }
  fn #3 : () -> Int ! pure
  {
    $result = load $2 : Int
  }
  fn #4 : () -> Int ! pure
  {
    $result = load $0 : Int
  }
}

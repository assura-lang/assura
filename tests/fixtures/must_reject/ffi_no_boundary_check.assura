// MUST REJECT A11001
// BLOCKED: #145 -- FFI boundary checker requires specific boundary violation pattern
module test.ffi_unsafe;

extern fn c_malloc(size: Nat) -> Nat
    boundary true
    requires { size > 0 }
    ensures { result > 0 }

extern fn c_free(ptr: Nat) -> Unit
    requires { ptr > 0 }
    ensures { true }


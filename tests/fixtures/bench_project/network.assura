// Network protocol contracts

contract Packet00 {
  input { size: Int, header_len: Int, payload_len: Int }
  output { result: Int }
  requires { size > 0 }
  requires { header_len >= 0 }
  requires { payload_len >= 0 }
  requires { header_len + payload_len <= size }
  ensures { header_len + payload_len <= size }
  ensures { size > 0 }
}


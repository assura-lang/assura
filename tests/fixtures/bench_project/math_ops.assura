// Math operation contracts

contract MathOp00 {
  input { x: Int, y: Int }
  output { result: Int }
  requires { x >= 0 }
  requires { y > 0 }
  requires { x + y < 1000000 }
  ensures { x + y >= 0 }
  ensures { x >= 0 }
}


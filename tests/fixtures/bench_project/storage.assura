// Storage and persistence contracts

contract Store00 {
  input { key: Int, value: Int, capacity: Int }
  output { result: Bool }
  requires { key >= 0 }
  requires { value >= 0 }
  requires { capacity > 0 }
  requires { key < capacity }
  ensures { key < capacity }
  ensures { key >= 0 }
}


// Input validation contracts

contract Validate00 {
  input { data: Int, limit: Int, offset: Int }
  output { result: Bool }
  requires { data >= 0 }
  requires { limit > 0 }
  requires { offset >= 0 }
  requires { offset < limit }
  ensures { offset < limit }
  ensures { data >= 0 }
}

